<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>{{ meta.name }} · 简历</title>
<style>{{ css }}</style>
</head>
<body>
<main class="page">
  <header class="hd{% if meta.photo %} has-photo{% endif %}">
    {% if meta.photo %}<img class="photo" src="{{ meta.photo }}" alt="证件照">{% endif %}
    <h1 class="name">{{ meta.name }}</h1>
    {% if meta.intent or meta.intent_detail %}
    <div class="intent">
      {% if meta.intent %}求职意向：{{ meta.intent }}{% endif %}
      {% if meta.intent and meta.intent_detail %}<span> · </span>{% endif %}
      {% if meta.intent_detail %}<span class="intent-detail">{{ meta.intent_detail }}</span>{% endif %}
    </div>
    {% endif %}
    <div class="contact">
      {% set bits = [] %}
      {% if meta.phone %}{% set _ = bits.append(meta.phone) %}{% endif %}
      {% if meta.email %}{% set _ = bits.append(meta.email) %}{% endif %}
      {% if meta.location %}{% set _ = bits.append(meta.location) %}{% endif %}
      {% if meta.hometown %}{% set _ = bits.append('户籍：' ~ meta.hometown) %}{% endif %}
      {% if meta.gender %}{% set _ = bits.append(meta.gender) %}{% endif %}
      {% if meta.birth %}{% set _ = bits.append(meta.birth) %}{% endif %}
      {% if meta.wechat %}{% set _ = bits.append(meta.wechat) %}{% endif %}
      {% if meta.github %}{% set _ = bits.append(meta.github) %}{% endif %}
      {% if meta.website %}{% set _ = bits.append(meta.website) %}{% endif %}
      {% if meta.linkedin %}{% set _ = bits.append(meta.linkedin) %}{% endif %}
      {{ bits | join(' · ') }}
    </div>
    {% if meta.summary %}<p class="summary">{{ meta.summary }}</p>{% endif %}
  </header>

  {% for sec in sections %}
  <section class="sec">
    <h2 class="sec-title">{{ sec.title }}</h2>
    {% if sec.bullets %}
    <ul class="plain">{% for b in sec.bullets %}<li>{{ b }}</li>{% endfor %}</ul>
    {% endif %}
    {% if sec.entries %}
    <div class="rail">
      {% for e in sec.entries %}
      <article class="entry">
        <span class="dot"></span>
        {% if e.meta %}<div class="entry-meta">{{ e.meta }}</div>{% endif %}
        {% if e.title_parts %}
        <div class="entry-title">
          <strong>{{ e.title_parts[0] }}</strong>
          {% if e.title_parts|length > 1 %}<span class="entry-sub">{{ e.title_parts[1:] | join(' · ') }}</span>{% endif %}
        </div>
        {% endif %}
        {% if e.bullets %}<ul>{% for b in e.bullets %}<li>{{ b }}</li>{% endfor %}</ul>{% endif %}
      </article>
      {% endfor %}
    </div>
    {% endif %}
  </section>
  {% endfor %}
</main>
</body>
</html>
