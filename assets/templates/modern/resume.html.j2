<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>{{ meta.name }} · 简历</title>
<style>{{ css }}</style>
</head>
<body>
<table class="layout">
<tr>
  <td class="sidebar">
    {% if meta.photo %}<img class="photo" src="{{ meta.photo }}" alt="证件照">{% endif %}
    <h1 class="name">{{ meta.name }}</h1>
    {% if meta.intent %}<div class="intent">{{ meta.intent }}</div>{% endif %}
    {% if meta.intent_detail %}<div class="intent-detail">{{ meta.intent_detail }}</div>{% endif %}

    <div class="side-block">
      <h3>联系方式</h3>
      {% if meta.phone %}<div class="kv">{{ meta.phone }}</div>{% endif %}
      {% if meta.email %}<div class="kv">{{ meta.email }}</div>{% endif %}
      {% if meta.location %}<div class="kv">{{ meta.location }}</div>{% endif %}
      {% if meta.hometown %}<div class="kv">户籍：{{ meta.hometown }}</div>{% endif %}
      {% if meta.gender or meta.birth %}<div class="kv">{{ [meta.gender, meta.birth] | select | join(' · ') }}</div>{% endif %}
      {% if meta.wechat %}<div class="kv">{{ meta.wechat }}</div>{% endif %}
      {% if meta.github %}<div class="kv">{{ meta.github }}</div>{% endif %}
      {% if meta.website %}<div class="kv">{{ meta.website }}</div>{% endif %}
      {% if meta.linkedin %}<div class="kv">{{ meta.linkedin }}</div>{% endif %}
    </div>

    {% for sec in sidebar %}
    <div class="side-block">
      <h3>{{ sec.title }}</h3>
      {% for b in sec.bullets %}<div class="kv">{{ b }}</div>{% endfor %}
      {% for e in sec.entries %}
        <div class="kv side-entry">
          {% if e.title_parts %}<strong>{{ e.title_parts | join(' · ') }}</strong>{% endif %}
          {% if e.meta %}<span class="side-meta">{{ e.meta }}</span>{% endif %}
        </div>
        {% for b in e.bullets %}<div class="kv">{{ b }}</div>{% endfor %}
      {% endfor %}
    </div>
    {% endfor %}

    {% if meta.summary %}
    <div class="side-block">
      <h3>个人优势</h3>
      <p class="side-summary">{{ meta.summary }}</p>
    </div>
    {% endif %}
  </td>

  <td class="main">
    {% for sec in main %}
    <section class="sec">
      <h2 class="sec-title">{{ sec.title }}</h2>
      {% if sec.bullets %}<ul class="plain">{% for b in sec.bullets %}<li>{{ b }}</li>{% endfor %}</ul>{% endif %}
      {% for e in sec.entries %}
      <div class="entry">
        {% if e.title_parts or e.meta %}
        <div class="entry-head">
          <span class="entry-title">
            {% if e.title_parts %}<strong>{{ e.title_parts[0] }}</strong>{% endif %}
            {% if e.title_parts|length > 1 %}<span class="entry-sub">{{ e.title_parts[1:] | join(' · ') }}</span>{% endif %}
          </span>
          {% if e.meta %}<span class="entry-meta">{{ e.meta }}</span>{% endif %}
        </div>
        {% endif %}
        {% if e.bullets %}<ul>{% for b in e.bullets %}<li>{{ b }}</li>{% endfor %}</ul>{% endif %}
      </div>
      {% endfor %}
    </section>
    {% endfor %}
  </td>
</tr>
</table>
</body>
</html>
